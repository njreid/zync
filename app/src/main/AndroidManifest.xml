<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- Recording voice notes (double-Volume-Up capture gesture). -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <!-- Native home agenda (personal calendars) + Open-Meteo weather (coarse only).
         Both are requested in-context from tappable rows, never on startup. -->
    <uses-permission android:name="android.permission.READ_CALENDAR" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- Package visibility for the launcher surfaces (spec L3): the swipe-left search
         lists every launchable app; the web-search row hands off to the search agent. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent>
        <intent>
            <action android:name="android.intent.action.WEB_SEARCH" />
        </intent>
    </queries>

    <!--
      allowBackup is off: durability is the central server (op-log sync + litestream),
      not Android Auto Backup — which would otherwise upload the op-log DB AND the
      replica's device key material to Google's cloud in cleartext-at-rest,
      contradicting the on-device-secrets posture.
    -->
    <application
        android:name=".ZyncApp"
        android:allowBackup="false"
        android:enableOnBackInvokedCallback="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:windowSoftInputMode="adjustResize"
        android:networkSecurityConfig="@xml/network_security_config"
        android:theme="@style/Theme.Zync">
        <!-- configChanges: keep the single WebView (and its live loopback connection) across
             rotation/resize instead of recreating the activity, which would reload :web. -->
        <!-- launchMode singleTask: a tapped zync://pair link re-enters the running
             instance via onNewIntent instead of stacking a second WebView shell. -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden|smallestScreenSize|density|uiMode">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- zync as the HOME app (launcher spec L2): pressing home surfaces the GTD
                 home screen. Only takes effect when the user grants ROLE_HOME (prompted
                 once; changeable any time in system settings). -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.HOME" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
            <!-- Server pairing deep link: the QR / link on /settings/pairing carries
                 zync://pair?h=&k=&c=&e= (see replica/Pairing.kt PairingUri). -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="zync" android:host="pair" />
            </intent-filter>
        </activity>

        <!--
          Share target: "Share → zync" from any app to drop audio (voice notes)
          or a PDF (scanned docs) into the Inbox. Invisible/translucent — it
          imports, toasts, and finishes (see attach/ShareReceiverActivity).
        -->
        <activity
            android:name=".attach.ShareReceiverActivity"
            android:exported="true"
            android:excludeFromRecents="true"
            android:taskAffinity=""
            android:theme="@android:style/Theme.Translucent.NoTitleBar">
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="audio/*" />
                <data android:mimeType="application/pdf" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.SEND_MULTIPLE" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="audio/*" />
                <data android:mimeType="application/pdf" />
            </intent-filter>
        </activity>

        <!-- Voice-note + document-scan capture screens, launched by the
             volume-key gestures (and reusable elsewhere). Not exported. -->
        <activity
            android:name=".capture.VoiceCaptureActivity"
            android:exported="false"
            android:theme="@android:style/Theme.Material.Light.Dialog" />
        <activity
            android:name=".capture.DocScanActivity"
            android:exported="false"
            android:theme="@android:style/Theme.Translucent.NoTitleBar" />
        <activity
            android:name=".capture.DocUploadActivity"
            android:exported="false"
            android:theme="@android:style/Theme.Translucent.NoTitleBar" />

        <!-- Accessibility service powering the global volume-key capture
             gestures: double Volume-Up = voice note, double Volume-Down = scan.
             The user enables it under Settings → Accessibility → zync. -->
        <service
            android:name=".capture.ZyncCaptureService"
            android:exported="true"
            android:label="@string/capture_service_label"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/capture_accessibility_service" />
        </service>

        <!-- Agenda-from-notifications: event/reminder notifications the calendars don't
             know about land on the home agenda (user enables listener access once). -->
        <service
            android:name=".home.ZyncNotificationListener"
            android:exported="false"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
        </service>

        <!-- Camera handoff for the capture screen's Photo mode. -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="dev.njr.zync.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <receiver
            android:name=".widget.QuickCaptureWidgetReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/quick_capture_widget_info" />
        </receiver>
    </application>

</manifest>
