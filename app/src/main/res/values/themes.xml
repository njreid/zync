<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Dark window chrome: the inset areas (status/nav bars) show the WINDOW
         background during layout and around edge-to-edge content — Light here was
         the white-bars bug. #13171F = the shared surface token. -->
    <style name="Theme.Zync" parent="android:Theme.Material.NoActionBar">
        <!-- Pure black for AMOLED power savings; cards carry the elevated tone. -->
        <item name="android:windowBackground">#FF000000</item>
        <item name="android:colorBackground">#FF000000</item>
    </style>
</resources>
