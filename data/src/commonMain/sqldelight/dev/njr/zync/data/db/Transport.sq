-- Server-only tables from op/merge spec §10. Defined here as part of the schema
-- deliverable; their queries land with the tasks that use them (op_log/sync_state in
-- the sync endpoints, M4 Task 2–3; operator_run in the operator runtime, M8).

-- Durable transport/audit log. `seq` is the server-assigned monotonic cursor (null
-- until ingested); `payload` is the full serialized Op JSON. Distinct from the
-- StateStore's applied_op ledger.
CREATE TABLE op_log (
  op_id TEXT NOT NULL PRIMARY KEY,
  seq INTEGER,
  entity_id TEXT NOT NULL,
  entity_type TEXT NOT NULL,
  op_type TEXT NOT NULL,
  payload TEXT NOT NULL,
  hlc_physical INTEGER NOT NULL,
  hlc_counter INTEGER NOT NULL,
  hlc_device TEXT NOT NULL,
  device_id TEXT NOT NULL,
  wall_clock INTEGER NOT NULL,
  synced INTEGER NOT NULL DEFAULT 0
);

insertOp:
INSERT OR IGNORE INTO op_log(op_id, seq, entity_id, entity_type, op_type, payload, hlc_physical, hlc_counter, hlc_device, device_id, wall_clock, synced)
VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?);

opExists:
SELECT COUNT(*) FROM op_log WHERE op_id = ?;

headSeq:
SELECT COALESCE(MAX(seq), 0) FROM op_log;

selectSince:
SELECT payload FROM op_log WHERE seq > ? ORDER BY seq ASC LIMIT ?;

selectRecent:
SELECT payload FROM op_log ORDER BY seq DESC LIMIT ?;

-- Phone (replica): locally-authored ops awaiting push, in creation order.
selectUnsynced:
SELECT payload FROM op_log WHERE synced = 0 ORDER BY rowid;

markSynced:
UPDATE op_log SET synced = 1 WHERE op_id = ?;

-- Compaction + quota (M9). Server-only: the materialized state tables hold the
-- merged CRDT state, so op_log rows at or below the compaction floor are
-- redundant transport/audit history once bootstrap (snapshot + tail) exists.

countOps:
SELECT COUNT(*) FROM op_log;

-- Approximate op-log payload size (TEXT length; chars ≈ bytes for JSON payloads).
oplogBytes:
SELECT COALESCE(SUM(LENGTH(payload)), 0) FROM op_log;

-- The first seq authored at/after :cutoff wall-clock; -1 when none is that recent.
firstSeqAtOrAfterWallClock:
SELECT COALESCE(MIN(seq), -1) FROM op_log WHERE wall_clock >= ? AND seq IS NOT NULL;

deleteOpsThroughSeq:
DELETE FROM op_log WHERE seq IS NOT NULL AND seq <= ?;

-- Per-peer pull cursor (max seq seen).
CREATE TABLE sync_state (
  peer TEXT NOT NULL PRIMARY KEY,
  cursor INTEGER NOT NULL
);

getCursor:
SELECT cursor FROM sync_state WHERE peer = ?;

setCursor:
INSERT OR REPLACE INTO sync_state(peer, cursor) VALUES (?, ?);

-- The lowest real peer cursor (excluding the reserved compaction-floor row); -1 when none.
minPeerCursor:
SELECT COALESCE(MIN(cursor), -1) FROM sync_state WHERE peer != ?;

-- Operator idempotency ledger (M8): a firing is keyed by (operator, entity, version).
CREATE TABLE operator_run (
  operator_id TEXT NOT NULL,
  entity_id TEXT NOT NULL,
  input_version TEXT NOT NULL,
  status TEXT NOT NULL,
  PRIMARY KEY (operator_id, entity_id, input_version)
);
