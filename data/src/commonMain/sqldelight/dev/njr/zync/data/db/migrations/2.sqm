-- v2 → v3: the agenda side channel (externally-pushed calendar events).
CREATE TABLE agenda_event (
  source TEXT NOT NULL,
  title TEXT NOT NULL,
  begin_ms INTEGER NOT NULL,
  end_ms INTEGER NOT NULL,
  all_day INTEGER NOT NULL DEFAULT 0,
  profile TEXT NOT NULL DEFAULT 'WORK'
);
CREATE INDEX agenda_event_source ON agenda_event(source);
