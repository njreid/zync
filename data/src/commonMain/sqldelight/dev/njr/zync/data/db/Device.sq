-- Paired devices: the allow-list of Ed25519 public keys the server accepts signed
-- requests from. Populated by the pairing flow; survives restarts. `replica_id` is
-- the phone's op-authoring id, bound immutably at pairing (nullable only for rows
-- paired before schema v2 — such devices must re-pair before they can push).
CREATE TABLE device (
  device_id TEXT NOT NULL PRIMARY KEY,
  public_key TEXT NOT NULL,   -- base64
  revoked INTEGER NOT NULL DEFAULT 0,
  paired_at INTEGER NOT NULL,
  replica_id TEXT
);

upsertDevice:
INSERT OR REPLACE INTO device(device_id, public_key, revoked, paired_at, replica_id)
VALUES (?, ?, 0, ?, ?);

getDevice:
SELECT public_key, revoked, replica_id FROM device WHERE device_id = ?;

revokeDevice:
UPDATE device SET revoked = 1 WHERE device_id = ?;

allDevices:
SELECT device_id, public_key, revoked FROM device;
