-- Registered browser passkeys (WebAuthn). Single-user server: the admin enrols one or
-- more passkeys, each stored as its credential id + serialized attested-credential-data
-- (the COSE public key, via webauthn4j's AttestedCredentialDataConverter) + a signature
-- counter that must only ever increase. Survives restarts.
CREATE TABLE webauthn_credential (
  credential_id TEXT NOT NULL PRIMARY KEY,       -- base64url(rawId)
  user_handle TEXT NOT NULL,                     -- base64url
  attested_credential_data TEXT NOT NULL,        -- base64 (AttestedCredentialDataConverter)
  sign_count INTEGER NOT NULL,
  created_at INTEGER NOT NULL
);

insertCredential:
INSERT INTO webauthn_credential(credential_id, user_handle, attested_credential_data, sign_count, created_at)
VALUES (?, ?, ?, ?, ?);

getCredential:
SELECT credential_id, user_handle, attested_credential_data, sign_count
FROM webauthn_credential WHERE credential_id = ?;

allCredentials:
SELECT credential_id, user_handle, attested_credential_data, sign_count
FROM webauthn_credential;

updateSignCount:
UPDATE webauthn_credential SET sign_count = ? WHERE credential_id = ?;

countCredentials:
SELECT COUNT(*) FROM webauthn_credential;
